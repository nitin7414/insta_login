# Neon pooled PostgreSQL connection string used by Prisma Client at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Optional direct Neon connection string for Prisma CLI migrations/generate.
# If omitted, prisma.config.ts falls back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Required to view /admin/moderation. Use a long random value.
ADMIN_TOKEN="replace-with-a-long-random-token"
