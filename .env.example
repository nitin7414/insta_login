# Neon pooled PostgreSQL connection string used by Prisma Client at runtime. Keep sslmode=require for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/dbname?sslmode=require"

# Optional direct Neon connection string used by Prisma CLI commands such as migrate.
# If omitted, Prisma CLI falls back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/dbname?sslmode=require"

# Required to view /admin/moderation. Use a long random value.
ADMIN_TOKEN="replace-with-a-long-random-token"
